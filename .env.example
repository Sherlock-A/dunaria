# Copy to .env.local and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Brevo (primary CRM + email automation)
# Create account at https://www.brevo.com — free tier: 300 emails/day
# API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Brevo list IDs (create 2 lists in Brevo dashboard):
#   List 1 "Tour Leads"        — collects prénom, nom, téléphone, email, tour
#   List 2 "Blog Subscribers"  — collects email only
BREVO_TOUR_LIST_ID=2
BREVO_BLOG_LIST_ID=3

# MailerLite (fallback, only used if BREVO_API_KEY is empty)
MAILERLITE_API_KEY=
MAILERLITE_TOUR_GROUP_ID=
MAILERLITE_GROUP_ID=

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# Espace Admin sécurisé
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (pour les analytics + contacts)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Identifiants admin
ADMIN_USERNAME=admin
# Générer le hash: node -e "require('bcryptjs').hash('VotreMotDePasse',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Clé secrète JWT (chaîne aléatoire ≥ 32 caractères)
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
